<Window x:Class="Паттерн_MVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MVVM To-Do" Height="650" Width="1080" MinHeight="560" MinWidth="900"
        Background="#F4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2E7D6B" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#20584C" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B33A3A" />
        <SolidColorBrush x:Key="InkBrush" Color="#172026" />
        <SolidColorBrush x:Key="MutedBrush" Color="#60707A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E7EDF0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="#C7D2D8" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#842929" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#C7D2D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TotalCount, StringFormat=Всего: {0}}" Margin="18,0,0,0" Foreground="{StaticResource MutedBrush}" />
                <TextBlock Text="{Binding ActiveCount, StringFormat=Активных: {0}}" Margin="18,0,0,0" Foreground="{StaticResource MutedBrush}" />
                <TextBlock Text="{Binding CompletedCount, StringFormat=Выполнено: {0}}" Margin="18,0,0,0" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Список задач" FontSize="28" FontWeight="Bold" />
                <TextBlock Text="Локальное To-Do приложение на паттерне MVVM" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Background="#D8ECE7" BorderBrush="#A9D1C6" BorderThickness="1" Padding="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="{StaticResource AccentDarkBrush}" FontWeight="SemiBold" />
                <ProgressBar Grid.Column="1" Height="10" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="480" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="1.05*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="#D5DEE3" BorderThickness="1" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <ComboBox DockPanel.Dock="Right" Width="180"
                                  ItemsSource="{Binding FilterOptions}"
                                  SelectedItem="{Binding SelectedFilter}"
                                  DisplayMemberPath="Title" />
                        <TextBlock Text="Задачи" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding VisibleTasks}"
                              SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              BorderBrush="#D5DEE3"
                              BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelectedForBatch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="48" />
                            <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="1.25*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="1.7*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="110" IsReadOnly="True" />
                            <DataGridTextColumn Header="Создана" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="140" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="Удалить выбранную" Command="{Binding DeleteSelectedTaskCommand}" Style="{StaticResource DangerButtonStyle}" />
                        <Button Content="Удалить отмеченные" Command="{Binding DeleteCheckedTasksCommand}" Style="{StaticResource DangerButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="#D5DEE3" BorderThickness="1" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Карточка задачи" FontSize="20" FontWeight="Bold" Margin="0,0,0,18" />

                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="Название" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox Text="{Binding TitleInput, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,12">
                        <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBox Text="{Binding DescriptionInput, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="500"
                                 Height="150"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top" />
                    </StackPanel>

                    <CheckBox Grid.Row="3"
                              Content="Выполнена"
                              IsChecked="{Binding IsCompletedInput}"
                              VerticalAlignment="Top"
                              Margin="0,4,0,0" />

                    <TextBlock Grid.Row="4"
                               Text="{Binding ValidationMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               MinHeight="28"
                               Margin="0,0,0,8" />

                    <WrapPanel Grid.Row="5">
                        <Button Content="Добавить" Command="{Binding AddTaskCommand}" />
                        <Button Content="Сохранить" Command="{Binding SaveTaskCommand}" />
                        <Button Content="Очистить" Command="{Binding ClearFormCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="Данные сохраняются в локальном JSON-файле. Операции добавления, изменения и удаления выполняются с имитацией задержки."
                   Foreground="{StaticResource MutedBrush}"
                   Margin="0,14,0,0" />
    </Grid>
</Window>
